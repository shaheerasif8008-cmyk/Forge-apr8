# ================================================================
# Forge Factory — Local Development Environment
# Copy to .env and fill in real values.
# ================================================================

# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
HUMAN_REVIEW_REQUIRED=true
MAX_GENERATION_ITERATIONS=5
EVALUATOR_TIMEOUT_SECONDS=600

# Database
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5432/forge
AUTO_INIT_DB=true

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Object Storage (MinIO locally, S3 in prod)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=forge-packages

# Auth
FACTORY_JWT_SECRET=change-me-before-non-local-use

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# LLM routing (all via litellm)
LLM_PRIMARY_MODEL=openrouter/anthropic/claude-3.5-sonnet
LLM_FALLBACK_MODEL=openrouter/openai/gpt-4o
LLM_REASONING_MODEL=openrouter/openai/o4-mini
LLM_SAFETY_MODEL=openrouter/anthropic/claude-3.5-haiku
LLM_FAST_MODEL=openrouter/anthropic/claude-3.5-haiku
EMBEDDING_MODEL=openai/text-embedding-3-large

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Tool integrations (optional for dev)
TAVILY_API_KEY=
COMPOSIO_API_KEY=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
